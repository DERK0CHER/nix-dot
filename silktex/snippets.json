{
  "Use Package": {
    "prefix": "upkg",
    "accelerator": "u",
    "body": "\\usepackage{$1}$0",
    "description": "Use Package"
  },
  "Environment": {
    "prefix": "begin",
    "accelerator": "b",
    "body": [
      "\\begin{${1:env}}",
      "\t$0",
      "\\end{$1}"
    ],
    "description": "Environment"
  },
  "Tabular": {
    "prefix": "tab",
    "accelerator": "t",
    "body": [
      "\\begin{${1:tabular}}{${2:c}}",
      "\t$0",
      "\\end{$1}"
    ],
    "description": "Tabular"
  },
  "Image": {
    "prefix": "img",
    "accelerator": "g",
    "body": [
      "\\begin{figure}[htp]",
      "\\centering",
      "\\includegraphics[scale=${1:1.0}]{$2}",
      "\\caption{$3}",
      "\\label{$4}",
      "\\end{figure}",
      "$0"
    ],
    "description": "Image"
  },
  "Align": {
    "prefix": "ali",
    "accelerator": "a",
    "body": [
      "\\begin{align${1:ed}}",
      "\t$0",
      "\\end{align$1}"
    ],
    "description": "Align"
  },
  "Gather": {
    "prefix": "gat",
    "body": [
      "\\begin{gather${1:ed}}",
      "\t$0",
      "\\end{gather$1}"
    ],
    "description": "Gather"
  },
  "Equation environment": {
    "prefix": "eq",
    "accelerator": "e",
    "body": [
      "\\begin{equation}",
      "\t$0",
      "\\end{equation}"
    ],
    "description": "Equation environment"
  },
  "Unnumbered Equation": {
    "prefix": "ueq",
    "body": [
      "\\[",
      "\t$0",
      "\\]"
    ],
    "description": "Unnumbered Equation"
  },
  "Aligned Equation": {
    "prefix": "aeq",
    "body": [
      "\\begin{align*}",
      "\t$0",
      "\\end{align*}"
    ],
    "description": "Aligned Equation"
  },
  "Aligned-Numbered Equation": {
    "prefix": "aneq",
    "body": [
      "\\begin{align}",
      "\t$0",
      "\\end{align}"
    ],
    "description": "Aligned-Numbered Equation"
  },
  "Enumerate": {
    "prefix": "enum",
    "accelerator": "n",
    "body": [
      "\\begin{enumerate}",
      "\t\\item $0",
      "\\end{enumerate}"
    ],
    "description": "Enumerate"
  },
  "Itemize": {
    "prefix": "item",
    "accelerator": "i",
    "body": [
      "\\begin{itemize}",
      "\t\\item $0",
      "\\end{itemize}"
    ],
    "description": "Itemize"
  },
  "Description": {
    "prefix": "desc",
    "accelerator": "d",
    "body": [
      "\\begin{description}",
      "\t\\item[${1}] $0",
      "\\end{description}"
    ],
    "description": "Description"
  },
  "Matrix": {
    "prefix": "mat",
    "accelerator": "m",
    "body": [
      "$\\begin{${1:p/b/v/V/B/small}matrix}",
      "\t$0",
      "\\end{$1matrix}$"
    ],
    "description": "Matrix"
  },
  "Cases": {
    "prefix": "cas",
    "accelerator": "c",
    "body": [
      "\\begin{cases}",
      "\t${1:equation}, &\\text{ if }${2:case}\\\\",
      "\t$0",
      "\\end{cases}"
    ],
    "description": "Cases"
  },
  "Split": {
    "prefix": "spl",
    "accelerator": "s",
    "body": [
      "\\begin{split}",
      "\t$0",
      "\\end{split}"
    ],
    "description": "Split"
  },
  "Part": {
    "prefix": "part",
    "body": [
      "\\part{${1:part name}}",
      "\\label{prt:${2}}",
      "$0",
      "% part $2 (end)"
    ],
    "description": "Part"
  },
  "Chapter": {
    "prefix": "cha",
    "body": [
      "\\chapter{${1:chapter name}}",
      "\\label{cha:${2}}",
      "$0",
      "% chapter $2 (end)"
    ],
    "description": "Chapter"
  },
  "Section": {
    "prefix": "sec",
    "body": [
      "\\section{${1:section name}}",
      "\\label{sec:${2}}",
      "$0",
      "% section $2 (end)"
    ],
    "description": "Section"
  },
  "Sub Section": {
    "prefix": "sub",
    "body": [
      "\\subsection{${1:subsection name}}",
      "\\label{sub:${2}}",
      "$0",
      "% subsection $2 (end)"
    ],
    "description": "Sub Section"
  },
  "Sub Sub Section": {
    "prefix": "subs",
    "body": [
      "\\subsubsection{${1:subsubsection name}}",
      "\\label{ssub:${2}}",
      "$0",
      "% subsubsection $2 (end)"
    ],
    "description": "Sub Sub Section"
  },
  "Paragraph": {
    "prefix": "par",
    "body": [
      "\\paragraph{${1:paragraph name}}",
      "\\label{par:${2}}",
      "$0",
      "% paragraph $2 (end)"
    ],
    "description": "Paragraph"
  },
  "Sub Paragraph": {
    "prefix": "subp",
    "body": [
      "\\subparagraph{${1:subparagraph name}}",
      "\\label{subp:${2}}",
      "$0",
      "% subparagraph $2 (end)"
    ],
    "description": "Sub Paragraph"
  },
  "Item": {
    "prefix": "itd",
    "body": "\\item[${1:description}] ${2:item}$0",
    "description": "Item"
  },
  "Figure Reference": {
    "prefix": "figure",
    "body": "Figure~\\ref{${2:fig:}}$0",
    "description": "Figure Reference"
  },
  "Table Reference": {
    "prefix": "table",
    "body": "Table~\\ref{${2:tab:}}$0",
    "description": "Table Reference"
  },
  "Listing Reference": {
    "prefix": "listing",
    "body": "Listing~\\ref{${2:list}}$0",
    "description": "Listing Reference"
  },
  "Section Reference": {
    "prefix": "section",
    "body": "Section~\\ref{${2:sec:}}$0",
    "description": "Section Reference"
  },
  "Page Reference": {
    "prefix": "page",
    "body": "${1:page}~\\pageref{${2}}$0",
    "description": "Page Reference"
  },
  "Fraction": {
    "prefix": "frac",
    "accelerator": "f",
    "body": "\\frac{$1}{$2}$0",
    "description": "Fraction"
  },
  "Curly braces": {
    "prefix": "cbrace",
    "body": "\\left \\{ $1 \\right \\}$0",
    "description": "Curly braces"
  }
}
