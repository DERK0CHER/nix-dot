# Generated by wallust — do not edit. dunst is launched with
#   dunst -config ~/.cache/wallust/dunstrc
# and reloaded via `dunstctl reload`. Edit the tracked source at
# ~/.config/dunst/dunstrc and mirror changes here (this is the themed copy).
[global]
    monitor = 0
    follow = mouse

    width = (0, 360)
    height = 200
    origin = top-right
    offset = 12x12
    scale = 0
    notification_limit = 5

    progress_bar = true
    progress_bar_height = 4
    progress_bar_frame_width = 0
    progress_bar_min_width = 150
    progress_bar_max_width = 300
    progress_bar_corner_radius = 2

    indicate_hidden = yes
    transparency = 18
    separator_height = 1
    padding = 14
    horizontal_padding = 14
    text_icon_padding = 10
    frame_width = 1
    frame_color = "#F08A3C"
    gap_size = 6
    separator_color = "#F08A3C"
    sort = yes

    font = BB Torsos Pro Ultra 11
    line_height = 2
    markup = full
    format = "<span letter_spacing='2048'><b>%s</b>\n%b</span>"
    alignment = left
    vertical_alignment = center
    show_age_threshold = 60
    ellipsize = middle
    ignore_newline = no
    stack_duplicates = true
    hide_duplicate_count = false
    show_indicators = no

    icon_theme = "Adwaita"
    enable_recursive_icon_lookup = true
    icon_position = left
    min_icon_size = 32
    max_icon_size = 48
    icon_corner_radius = 4

    sticky_history = yes
    history_length = 20

    browser = /usr/bin/xdg-open
    always_run_script = true
    title = Dunst
    class = Dunst
    corner_radius = 12

    mouse_left_click = close_current
    mouse_middle_click = do_action, close_current
    mouse_right_click = close_all

    layer = overlay
    force_xwayland = false

[urgency_low]
    background = "{{background}}"
    foreground = "{{color8}}"
    frame_color = "{{color8}}"
    timeout = 4

[urgency_normal]
    background = "{{background}}"
    foreground = "{{foreground}}"
    frame_color = "#F08A3C"
    timeout = 7

[urgency_critical]
    background = "{{background}}"
    foreground = "{{color1}}"
    frame_color = "{{color1}}"
    timeout = 0
